rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Notifications: Users can read their own notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated(); // For system-generated notifications
      allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // Network: Users can manage their own professional network
    match /network/{networkId} {
      allow read, create, update, delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || request.resource.data.userId == request.auth.uid);
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
